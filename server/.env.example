# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────
# Same Postgres instance as the FastAPI backend
DATABASE_URL=postgresql://user:password@localhost:5432/movecred

# ── Clerk ─────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Lemon Squeezy ─────────────────────────────────────────────────
# Get from https://app.lemonsqueezy.com → Settings → Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret

# Checkout URL for the Pro variant (Lemon Squeezy product page)
# Add ?checkout[custom][clerk_user_id]= dynamically in frontend
LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/YOUR_VARIANT_ID

# ── CORS ──────────────────────────────────────────────────────────
# Origin(s) that can call this server
ALLOWED_ORIGIN=http://localhost:3001
