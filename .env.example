# ── Copy to .env and fill in your values ──────────────────────────────────────

# App
APP_NAME=MoveCred
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql+psycopg2://movecred:movecred@localhost:5432/movecred

# Market data provider
# "yfinance" for prototype | "polygon" for production
MARKET_DATA_PROVIDER=yfinance
POLYGON_API_KEY=
IEX_API_KEY=
FINNHUB_API_KEY=

# Universe configuration
ACTIVE_UNIVERSE_SIZE=50
ACTIVE_UNIVERSE_MIN_PRICE=5.0
ACTIVE_UNIVERSE_MIN_VOLUME=500000

# Feature engineering
FEATURE_VERSION=v1
MIN_HISTORY_DAYS=252

# Label thresholds
CONTINUATION_THRESHOLD_PCT=1.0
DRAWDOWN_THRESHOLD_PCT=3.0
MEAN_REVERT_THRESHOLD_PCT=2.0

# Model
MODEL_VERSION=v1
MODEL_ARTIFACTS_PATH=app/models/artifacts
CALIBRATION_METHOD=isotonic

# Walk-forward
WF_TRAIN_YEARS=3
WF_TEST_MONTHS=3

# API
SECRET_KEY=change-me-in-production
ALLOW_ORIGINS=["*"]

# Scheduler (ET timezone)
JOBS_TIMEZONE=America/New_York
DAILY_INGEST_HOUR=17
DAILY_INGEST_MINUTE=0
DAILY_PREDICT_HOUR=17
DAILY_PREDICT_MINUTE=30
DAILY_DIGEST_HOUR=18
DAILY_DIGEST_MINUTE=0

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
